# dotMarket Keeper Bot — Environment Variables
# Copy this file to .env and fill in the values

# ARC Testnet RPC endpoint
ARC_TESTNET_RPC=https://rpc.testnet.arc.network

# Private key of the keeper wallet (without 0x prefix)
KEEPER_PRIVATE_KEY=901578242d9c94e41fde9a493f08fe21c5ec5012f07342a9643a7194d8a3e14a

# Deployed RoundMarket contract address
MARKET_ADDRESS=0x3Dae61C2103cc71a9fAa3803965300D48d9885b8

# Pyth Hermes URL (optional, defaults shown)
HERMES_URL=https://hermes-beta.pyth.network

# Pyth price feed ID — BTC/USD by default (Testnet ID)
# See https://pyth.network/developers/price-feed-ids for other feeds
PRICE_FEED_ID=0xf9c0172ba10dfa4d19088d94f5bf61d3b54d5bd7483a322a982e1373ee8ea31b
